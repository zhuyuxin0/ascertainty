# Caddy reverse proxy — TLS-terminates api.ascertainty.xyz with auto-renewing
# Let's Encrypt certs and proxies to the FastAPI container on port 8000.

{
    # Email used by Let's Encrypt for renewal notices. Sourced from the
    # LE_EMAIL env var on the VPS so this file can stay public.
    email {env.LE_EMAIL}
}

api.ascertainty.xyz {
    encode zstd gzip

    # Pass everything to the FastAPI app
    reverse_proxy api:8000

    # Sensible logging
    log {
        output stdout
        format console
    }
}
